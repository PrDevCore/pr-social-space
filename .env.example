# Legacy aliases kept for compatibility with older Clerk deployments.
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Post for Me (social posting API) ---
# Server-side ONLY. Never expose this to the browser.
POSTFORME_API_KEY=pfm_xxxxxxxxxxxxxxxxxxxxxxxx
POSTFORME_API_BASE=https://api.postforme.dev

# Used for building the return trip after a user connects a social account.
# Quickstart projects: set this in the Post for Me dashboard instead and
# omit redirect_url_override in code (see lib/postforme.ts).
# White Label projects: set this and it will be sent as redirect_url_override.
APP_URL=http://localhost:3000
POSTFORME_PROJECT_MODE=quickstart # "quickstart" | "white_label"

# Optional: signing secret for the Post for Me webhook (social.account.created, etc.)
POSTFORME_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
